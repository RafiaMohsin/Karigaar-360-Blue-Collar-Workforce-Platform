@page
@{
    ViewData["Title"] = "Customer Registration | Karigaar 360";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Registration | Karigaar 360</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body class="bg-light">

    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="index.html">
                <div class="logo-wrapper me-2">
                    <i class="fas fa-tools text-warning floating"></i>
                </div>
                <span class="fw-bold"
                    style="background: linear-gradient(45deg, var(--primary-color), var(--primary-light)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Karigaar
                    360</span>
            </a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" href="index.html">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="login.html">Login</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Registration Form -->
    <div class="container py-5">
        <div class="row justify-content-center animate-up">
            <div class="col-lg-8 col-xl-7">
                <div class="card shadow-lg p-4 p-md-5">
                    <div class="text-center mb-5">
                        <i class="fas fa-hand-holding-heart fa-3x text-primary mb-3"></i>
                        <h2 class="fw-bold">Create Customer Account</h2>
                        <p class="text-muted">Register to find the best Karigaars for your home or office.</p>
                    </div>

                    <form>
                        <div class="row g-3">
                            <div class="col-md-6 text-start">
                                <label class="form-label fw-semibold">Full Name</label>
                                <input type="text" class="form-control" placeholder="Enter your full name" required>
                            </div>
                            <div class="col-md-6 text-start">
                                <label class="form-label fw-semibold">Phone Number</label>
                                <input type="tel" class="form-control" placeholder="+92 300 1234567" required>
                            </div>
                            <div class="col-md-12 text-start">
                                <label class="form-label fw-semibold">Email Address (Optional)</label>
                                <input type="email" class="form-control" placeholder="example@email.com">
                            </div>
                            <div class="col-md-12 text-start">
                                <label class="form-label fw-semibold">Address / Default Location</label>
                                <textarea class="form-control" rows="2"
                                    placeholder="e.g. House #123, Street 5, Area..."></textarea>
                            </div>
                            <div class="col-md-12 text-start">
                                <label class="form-label fw-semibold">Password</label>
                                <input type="password" class="form-control" placeholder="Create a secure password"
                                    required>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-primary w-100 py-3 shadow">Sign Up as
                                    Customer</button>
                            </div>
                        </div>
                    </form>

                    <div class="text-center mt-4 pt-3 border-top">
                        <p class="mb-0">Already have an account? <a href="login.html"
                                class="text-primary fw-bold text-decoration-none">Login Here</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="mt-5">
        <div class="container">
            <div class="text-center opacity-50 pb-3">
                <small>&copy; 2026 Karigaar 360. All rights reserved.</small>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>