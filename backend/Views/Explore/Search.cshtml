@model Karigaar360.Controllers.SearchResultsViewModel

@{
    ViewData["Title"] = "Search Results - " + ViewBag.Query;
}

<div class="search-results-wrapper py-5">
    <div class="container">
        <div class="search-header mb-5 text-center">
            <h1 class="fw-bold">Search Results</h1>
            <p class="text-muted">Found results for "<span class="text-primary fw-bold">@ViewBag.Query</span>"</p>
        </div>

        <div class="row">
            <!-- Workers Section -->
            <div class="col-lg-12 mb-5">
                <div class="section-badge mb-4">
                    <span class="badge bg-primary px-3 py-2 rounded-pill"><i class="fas fa-tools me-2"></i>SKILLED KARIGAARS (@Model.Workers.Count)</span>
                </div>
                
                @if (Model.Workers.Any())
                {
                    <div class="row g-4">
                        @foreach (var worker in Model.Workers)
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="premium-card result-card p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="result-avatar bg-soft-primary me-3">
                                            @worker.FullName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">@worker.FullName</h5>
                                            <small class="text-primary fw-600">@worker.Profession</small>
                                        </div>
                                    </div>
                                    <div class="result-stats mb-3 d-flex gap-3">
                                        <small class="text-muted"><i class="fas fa-star text-warning me-1"></i>@worker.Rating.ToString("F1")</small>
                                        <small class="text-muted"><i class="fas fa-briefcase me-1"></i>@worker.TotalJobsCompleted Completed</small>
                                    </div>
                                    <div class="d-grid">
                                        <a asp-controller="Worker" asp-action="Profile" asp-route-id="@worker.Id" class="btn btn-premium-outline">View Profile</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state py-5 text-center rounded-4 bg-white shadow-sm">
                        <i class="fas fa-user-slash fa-3x text-muted opacity-25 mb-3"></i>
                        <p class="text-muted">No Karigaars found matching your search.</p>
                    </div>
                }
            </div>

            <!-- Customers Section -->
            <div class="col-lg-12">
                <div class="section-badge mb-4">
                    <span class="badge bg-secondary px-3 py-2 rounded-pill"><i class="fas fa-users me-2"></i>CUSTOMERS (@Model.Customers.Count)</span>
                </div>

                @if (Model.Customers.Any())
                {
                    <div class="row g-4">
                        @foreach (var customer in Model.Customers)
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="premium-card result-card p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="result-avatar bg-soft-secondary me-3">
                                            @customer.FullName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">@customer.FullName</h5>
                                            <small class="text-muted">Verified Client</small>
                                        </div>
                                    </div>
                                    <div class="d-grid">
                                        <a asp-controller="Customer" asp-action="Profile" asp-route-id="@customer.Id" class="btn btn-premium-outline-secondary">View Public Profile</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state py-5 text-center rounded-4 bg-white shadow-sm">
                        <i class="fas fa-search fa-3x text-muted opacity-25 mb-3"></i>
                        <p class="text-muted">No customers found matching your search.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .search-results-wrapper {
        min-height: calc(100vh - 300px);
        background-color: #f8f9fa;
    }

    .premium-card {
        background: #fff;
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
    }

    .result-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    }

    .result-avatar {
        width: 60px;
        height: 60px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 800;
        color: #007bff;
    }

    .bg-soft-primary { background-color: rgba(0,123,255,0.08); color: #007bff; }
    .bg-soft-secondary { background-color: rgba(108,117,125,0.08); color: #6c757d; }

    .btn-premium-outline {
        border: 2px solid #007bff;
        color: #007bff;
        font-weight: 700;
        border-radius: 12px;
        padding: 10px;
        transition: all 0.3s ease;
    }

    .btn-premium-outline:hover {
        background-color: #007bff;
        color: white;
    }

    .btn-premium-outline-secondary {
        border: 2px solid #6c757d;
        color: #6c757d;
        font-weight: 700;
        border-radius: 12px;
        padding: 10px;
        transition: all 0.3s ease;
    }

    .btn-premium-outline-secondary:hover {
        background-color: #6c757d;
        color: white;
    }

    .fw-600 { font-weight: 600; }
</style>
