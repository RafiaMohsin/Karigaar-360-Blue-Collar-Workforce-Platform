@{
    ViewData["Title"] = "Worker Login";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center animate-up">
        <div class="col-md-6 col-lg-5 col-xl-4">
            <div class="card shadow-lg border-0 p-4 p-md-5">
                <div class="text-center mb-5">
                    <div class="mb-4">
                        <i class="fas fa-hard-hat fa-4x text-primary opacity-25"></i>
                    </div>
                    <h2 class="fw-bold">Worker Login</h2>
                    <p class="text-muted">Welcome back to Karigaar 360</p>
                </div>

                @if (!string.IsNullOrEmpty(ViewBag.Error))
                {
                    <div class="alert alert-danger border-0 shadow-sm small mb-4">
                        <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-4">
                        <label class="form-label fw-bold">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-phone text-muted"></i></span>
                            <input type="text" name="phone" class="form-control border-start-0" placeholder="03001234567" required>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-lock text-muted"></i></span>
                            <input type="password" name="password" class="form-control border-start-0" placeholder="Your password" required>
                        </div>
                    </div>
                    <div class="col-12 mt-5">
                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill shadow-sm fw-bold">
                            Login as Karigaar
                        </button>
                    </div>
                </form>

                <div class="text-center mt-5 pt-3 border-top">
                    <p class="mb-0 text-muted">Don't have an account? <br> <a asp-controller="Worker" asp-action="Register" class="text-primary fw-bold text-decoration-none">Register as Karigaar</a></p>
                </div>
            </div>
        </div>
    </div>
</div>