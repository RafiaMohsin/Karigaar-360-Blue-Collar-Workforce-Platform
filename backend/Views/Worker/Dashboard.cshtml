@{
    ViewData["Title"] = "Worker Dashboard";
}

<div class="container py-5 mt-4">
    <div class="row g-4">
        <!-- Sidebar Info -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4 animate-up">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="fas fa-user-circle fa-6x text-primary opacity-25"></i>
                    </div>
                    <h3 class="fw-bold mb-1">@ViewBag.UserName</h3>
                    <p class="text-muted mb-4">Professional Karigaar</p>
                    <hr>
                    <div class="row text-center mt-4">
                        <div class="col-6 border-end">
                            <h4 class="fw-bold text-primary mb-0">@ViewBag.Rating.ToString("F1")</h4>
                            <small class="text-muted">Rating</small>
                        </div>
                        <div class="col-6">
                            <h4 class="fw-bold text-primary mb-0">@ViewBag.JobsCompleted</h4>
                            <small class="text-muted">Jobs</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 animate-up" style="animation-delay: 0.1s;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Quick Actions</h5>
                    <div class="d-grid gap-2">
                        <a asp-controller="Job" asp-action="Browse" class="btn btn-primary">
                            <i class="fas fa-search me-2"></i> Find New Jobs
                        </a>
                        <a asp-controller="Job" asp-action="MyAcceptedJobs" class="btn btn-outline-primary">
                            <i class="fas fa-tasks me-2"></i> My Active Jobs
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100 animate-up" style="animation-delay: 0.2s;">
                <div class="card-header bg-white border-0 py-4">
                    <h4 class="fw-bold mb-0">Dashboard Overview</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-info border-0 shadow-sm d-flex align-items-center p-4 mb-4">
                        <i class="fas fa-info-circle fa-2x me-3"></i>
                        <div>
                            <h6 class="fw-bold mb-1">Welcome back, @ViewBag.UserName!</h6>
                            <p class="mb-0 small">You have 3 new job opportunities in your area. Check them out now!</p>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="card p-4 border-0 bg-light shadow-sm">
                                <h6 class="text-muted fw-bold mb-2">Total Earnings</h6>
                                <h3 class="fw-bold text-primary mb-0">Rs. @ViewBag.TotalEarnings.ToString("N0")</h3>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card p-4 border-0 bg-light shadow-sm">
                                <h6 class="text-muted fw-bold mb-2">Jobs Completed</h6>
                                <h3 class="fw-bold text-primary mb-0">@ViewBag.JobsCompleted</h3>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 text-center p-5 opacity-50 bg-light rounded-4">
                        <i class="fas fa-chart-line fa-4x mb-3"></i>
                        <h5>Detailed Analytics</h5>
                        <p class="mb-0">More statistics will appear here as you complete more jobs.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>