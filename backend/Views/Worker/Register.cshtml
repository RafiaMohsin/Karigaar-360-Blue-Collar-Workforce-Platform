@model Karigaar360.Models.Worker
@{
    ViewData["Title"] = "Worker Registration";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center animate-up">
        <div class="col-lg-8 col-xl-7">
            <div class="card shadow-lg border-0 p-4 p-md-5">
                <div class="text-center mb-5">
                    <div class="mb-4">
                        <i class="fas fa-user-plus fa-4x text-primary opacity-25"></i>
                    </div>
                    <h2 class="fw-bold">Join as a Karigaar</h2>
                    <p class="text-muted">Register your skills and start finding jobs today.</p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="FullName" class="form-label fw-bold">Full Name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-user text-muted"></i></span>
                                <input asp-for="FullName" class="form-control border-start-0" placeholder="Enter your full name">
                            </div>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Phone" class="form-label fw-bold">Phone Number</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-phone text-muted"></i></span>
                                <input asp-for="Phone" class="form-control border-start-0" placeholder="+92 300 1234567">
                            </div>
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Profession" class="form-label fw-bold">Service Type</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-tools text-muted"></i></span>
                                <select asp-for="Profession" class="form-select border-start-0">
                                    <option value="">Choose your craft...</option>
                                    <option>Electrician</option>
                                    <option>Plumber</option>
                                    <option>Carpenter</option>
                                    <option>Painter</option>
                                    <option>AC Technician</option>
                                </select>
                            </div>
                            <span asp-validation-for="Profession" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ExperienceYears" class="form-label fw-bold">Experience <span class="text-muted fw-normal">(Years)</span></label>
                            <input asp-for="ExperienceYears" class="form-control" placeholder="e.g. 5">
                            <span asp-validation-for="ExperienceYears" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Location" class="form-label fw-bold">Location / Area</label>
                            <input asp-for="Location" class="form-control" placeholder="e.g. Gulshan, Karachi">
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="PasswordHash" class="form-label fw-bold">Create Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-lock text-muted"></i></span>
                                <input asp-for="PasswordHash" type="password" class="form-control border-start-0" placeholder="Minimum 8 characters">
                            </div>
                            <span asp-validation-for="PasswordHash" class="text-danger small"></span>
                        </div>
                        <div class="col-12 mt-5">
                            <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill shadow-sm fw-bold">
                                Create Worker Account
                            </button>
                        </div>
                    </div>
                </form>

                <div class="text-center mt-5 pt-3 border-top">
                    <p class="mb-0 text-muted">Already have an account? <a asp-controller="Worker" asp-action="Login" class="text-primary fw-bold text-decoration-none">Login Here</a></p>
                </div>
            </div>
        </div>
    </div>
</div>