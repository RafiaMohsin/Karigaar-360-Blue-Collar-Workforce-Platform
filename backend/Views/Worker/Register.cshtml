@model Karigaar360.Models.Worker
@{
    ViewData["Title"] = "Worker Registration";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Worker Registration | Karigaar 360</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <div class="logo-wrapper me-2">
                    <i class="fas fa-tools text-warning floating"></i>
                </div>
                <span class="fw-bold" style="background: linear-gradient(45deg, var(--primary-color), var(--primary-light)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Karigaar 360</span>
            </a>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row justify-content-center animate-up">
            <div class="col-lg-8 col-xl-7">
                <div class="card shadow-lg p-4 p-md-5">
                    <div class="text-center mb-5">
                        <i class="fas fa-user-plus fa-3x text-primary mb-3"></i>
                        <h2 class="fw-bold">Join as a Karigaar</h2>
                        <p class="text-muted">Register your skills and start finding jobs today.</p>
                    </div>

                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="row g-3">
                            <div class="col-md-12 text-start">
                                <label asp-for="FullName" class="form-label fw-semibold">Full Name</label>
                                <input asp-for="FullName" class="form-control" placeholder="Enter your full name">
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>
                            <div class="col-md-12 text-start">
                                <label asp-for="Phone" class="form-label fw-semibold">Phone Number</label>
                                <input asp-for="Phone" class="form-control" placeholder="+92 300 1234567">
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                            <div class="col-md-12 text-start">
                                <label asp-for="Profession" class="form-label fw-semibold">Service Type</label>
                                <select asp-for="Profession" class="form-select">
                                    <option value="">Choose your craft...</option>
                                    <option>Electrician</option>
                                    <option>Plumber</option>
                                    <option>Carpenter</option>
                                    <option>Painter</option>
                                    <option>AC Technician</option>
                                </select>
                                <span asp-validation-for="Profession" class="text-danger"></span>
                            </div>
                            <div class="col-md-12 text-start">
                                <label asp-for="ExperienceYears" class="form-label fw-semibold">Experience (Years)</label>
                                <input asp-for="ExperienceYears" class="form-control" placeholder="How many years of experience?">
                                <span asp-validation-for="ExperienceYears" class="text-danger"></span>
                            </div>
                            <div class="col-md-12 text-start">
                                <label asp-for="Location" class="form-label fw-semibold">Location / Area</label>
                                <input asp-for="Location" class="form-control" placeholder="e.g. Gulshan-e-Iqbal, Karachi">
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>
                            <div class="col-md-12 text-start">
                                <label asp-for="PasswordHash" class="form-label fw-semibold">Password</label>
                                <input asp-for="PasswordHash" type="password" class="form-control" placeholder="Create a secure password">
                                <span asp-validation-for="PasswordHash" class="text-danger"></span>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-primary w-100 py-3 shadow">Create Worker Account</button>
                            </div>
                        </div>
                    </form>

                    <div class="text-center mt-4 pt-3 border-top">
                        <p class="mb-0">Already have an account? <a asp-controller="Worker" asp-action="Login" class="text-primary fw-bold">Login Here</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="mt-5">
        <div class="container">
            <div class="text-center opacity-50 pb-3">
                <small>&copy; 2026 Karigaar 360. All rights reserved.</small>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>