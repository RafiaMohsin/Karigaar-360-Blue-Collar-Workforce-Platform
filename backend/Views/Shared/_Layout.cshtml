<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Karigaar360</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Karigaar360.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <div class="logo-wrapper me-2">
                        <i class="fas fa-tools text-warning floating"></i>
                    </div>
                    <span class="fw-bold">Karigaar 360</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item"><a class="nav-link mx-2" asp-controller="Home" asp-action="Index">Home</a></li>
                        
                        @if (Context.Session.GetInt32("CustomerId") != null)
                        {
                            <li class="nav-item"><a class="nav-link mx-2" asp-controller="Job" asp-action="Create">Post a Job</a></li>
                            <li class="nav-item"><a class="nav-link mx-2" asp-controller="Customer" asp-action="Dashboard">Dashboard</a></li>
                            <li class="nav-item ms-lg-3">
                                <a asp-controller="Customer" asp-action="Logout" class="btn btn-outline-primary rounded-pill px-4">Logout</a>
                            </li>
                        }
                        else if (Context.Session.GetInt32("WorkerId") != null)
                        {
                            <li class="nav-item"><a class="nav-link mx-2" asp-controller="Worker" asp-action="Dashboard">My Dashboard</a></li>
                            <li class="nav-item ms-lg-3">
                                <a asp-controller="Worker" asp-action="Logout" class="btn btn-outline-primary rounded-pill px-4">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link mx-2" asp-controller="Customer" asp-action="Login">Customer Login</a></li>
                            <li class="nav-item"><a class="nav-link mx-2" asp-controller="Worker" asp-action="Login">Worker Login</a></li>
                            <li class="nav-item ms-lg-3">
                                <a asp-controller="Customer" asp-action="Register" class="btn btn-outline-primary rounded-pill px-4">Join Us</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-auto">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <h5 class="fw-bold mb-3"><i class="fas fa-tools me-2 text-warning"></i>Karigaar 360</h5>
                    <p class="opacity-75">Empowering blue-collar workers and simplifying home services since 2024.</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h6 class="fw-bold mb-3">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Worker" asp-action="Register" class="footer-link">Register as Worker</a></li>
                        <li><a asp-controller="Customer" asp-action="Register" class="footer-link">Register as Customer</a></li>
                        <li><a asp-controller="Job" asp-action="Create" class="footer-link">Post a Job</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h6 class="fw-bold mb-3">Support</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="footer-link">Privacy Policy</a></li>
                        <li><a href="#" class="footer-link">Terms of Service</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy" class="footer-link">Contact Us</a></li>
                    </ul>
                </div>
            </div>
            <hr class="opacity-25 my-4">
            <div class="text-center opacity-50 pb-3">
                <small>&copy; 2026 Karigaar 360. All rights reserved.</small>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
