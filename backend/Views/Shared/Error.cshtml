@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center animate-up">
            <div class="card shadow-lg border-0 p-5 rounded-4">
                <div class="mb-4">
                    <i class="fas fa-exclamation-triangle fa-5x text-danger opacity-25"></i>
                </div>
                <h1 class="fw-bold text-danger mb-3">Something went wrong</h1>
                <p class="lead text-muted mb-5">We're sorry, but an unexpected error occurred while processing your request.</p>
                
                @if (Model.ShowRequestId)
                {
                    <div class="alert alert-light border-0 shadow-sm mb-5">
                        <small class="text-muted d-block text-uppercase fw-bold text-xs mb-1">Request ID</small>
                        <code class="fw-bold text-primary">@Model.RequestId</code>
                    </div>
                }

                <div class="d-grid gap-3">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill py-3 fw-bold shadow">
                        <i class="fas fa-home me-2"></i>Go to Home Page
                    </a>
                    <a href="javascript:history.back()" class="btn btn-outline-primary rounded-pill py-3 fw-bold">
                        <i class="fas fa-arrow-left me-2"></i>Go Back
                    </a>
                </div>
            </div>

            <div class="mt-5 opacity-50 small">
                <p>If you're in development mode, detailed information about the error can be found in the logs.</p>
            </div>
        </div>
    </div>
</div>
