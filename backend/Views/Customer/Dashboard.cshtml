@{
    ViewData["Title"] = "Customer Dashboard";
}

<div class="container py-5 mt-4">
    <div class="row g-4">
        <!-- Sidebar Info -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4 animate-up">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="fas fa-user-circle fa-6x text-primary opacity-25"></i>
                    </div>
                    <h3 class="fw-bold mb-1">@ViewBag.UserName</h3>
                    <p class="text-muted mb-4">Valued Customer</p>
                    <hr>
                    <div class="d-grid gap-2 mt-4">
                        <a asp-controller="Job" asp-action="Create" class="btn btn-primary rounded-pill">
                            <i class="fas fa-plus me-2"></i> Post a New Job
                        </a>
                        <a asp-controller="Job" asp-action="MyJobs" class="btn btn-outline-primary rounded-pill">
                            <i class="fas fa-list me-2"></i> View My Jobs
                        </a>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 animate-up" style="animation-delay: 0.1s;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Account Summary</h5>
                        <div class="list-group list-group-flush">
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span>Total Posts</span>
                            <span class="badge bg-primary rounded-pill">@ViewBag.TotalJobs</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span>Completed</span>
                            <span class="badge bg-success rounded-pill">@ViewBag.CompletedJobs</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span>Active</span>
                            <span class="badge bg-info rounded-pill text-dark">@ViewBag.ActiveJobs</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100 animate-up" style="animation-delay: 0.2s;">
                <div class="card-header bg-white border-0 py-4">
                    <h4 class="fw-bold mb-0">Recent Activity</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-success border-0 shadow-sm d-flex align-items-center p-4 mb-4">
                        <i class="fas fa-check-circle fa-2x me-3"></i>
                        <div>
                            <h6 class="fw-bold mb-1">Looking for help?</h6>
                            <p class="mb-0 small">Your latest job post has received 2 new quotes from verified Karigaars!</p>
                        </div>
                    </div>

                    <div class="mt-5 text-center p-5 opacity-50 bg-light rounded-4">
                        <i class="fas fa-history fa-4x mb-3"></i>
                        <h5>No Recent Notifications</h5>
                        <p class="mb-0">Your recent activities and job updates will appear here.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>