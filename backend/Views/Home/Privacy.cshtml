@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5 mt-4">
    <div class="card shadow-lg border-0 p-5 animate-up">
        <div class="mb-4 text-center">
            <i class="fas fa-shield-alt fa-4x text-primary opacity-25"></i>
        </div>
        <h1 class="fw-bold text-center mb-4">Privacy Policy</h1>
        <p class="lead text-muted text-center mb-5">At Karigaar 360, your privacy and data security are our top priorities.</p>
        
        <div class="row g-5">
            <div class="col-md-6">
                <h5 class="fw-bold mb-3"><i class="fas fa-user-secret me-2 text-primary"></i>Data Collection</h5>
                <p class="text-muted">We collect your name, phone number, and location to facilitate job matching between customers and workers. Your data is stored securely and never sold to third parties.</p>
            </div>
            <div class="col-md-6">
                <h5 class="fw-bold mb-3"><i class="fas fa-lock me-2 text-primary"></i>Secure Storage</h5>
                <p class="text-muted">All sensitive data, including passwords, are hashed and encrypted using industry-standard protocols. We prioritize the integrity of your personal information.</p>
            </div>
            <div class="col-md-6">
                <h5 class="fw-bold mb-3"><i class="fas fa-eye-slash me-2 text-primary"></i>Profile Visibility</h5>
                <p class="text-muted">Workers' profiles are visible to customers for hiring purposes. Customers' contact details are only shared with the assigned worker once a job is accepted.</p>
            </div>
            <div class="col-md-6">
                <h5 class="fw-bold mb-3"><i class="fas fa-user-shield me-2 text-primary"></i>Your Rights</h5>
                <p class="text-muted">You have the right to request access to your data or its deletion at any time by contacting our support team or through your account dashboard.</p>
            </div>
        </div>

        <div class="mt-5 pt-4 border-top text-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-5 shadow">Back to Home</a>
        </div>
    </div>
</div>
