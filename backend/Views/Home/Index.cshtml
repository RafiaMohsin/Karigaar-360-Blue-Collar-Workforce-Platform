@{
    ViewData["Title"] = "Karigaar 360 | Connecting Skilled Hands to Your Needs";
}

<!-- Hero Section -->
<section class="hero-section text-center text-lg-start">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 animate-up">
                <h1 class="hero-title">Connecting Skilled Karigaars to Your Doorstep</h1>
                <p class="lead mb-4 opacity-75">From plumbing to electrical work, find verified professionals for
                    every task. Reliable, skilled, and ready to help.</p>
                <div class="d-flex flex-column flex-sm-row gap-3">
                    <a asp-controller="Customer" asp-action="Register" class="btn btn-secondary btn-lg shadow">Hire a Karigaar</a>
                    <a asp-controller="Worker" asp-action="Register" class="btn btn-outline-light btn-lg text-white">Join as a Worker</a>
                </div>
            </div>
            <div class="col-lg-6 mt-5 mt-lg-0 text-center animate-up" style="animation-delay: 0.2s;">
                <div class="position-relative">
                    <div class="blob-bg"></div>
                    <i class="fas fa-hard-hat fa-10x text-warning opacity-50 floating"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Overview -->
<section class="py-5 mt-5">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="card p-4 h-100">
                    <div class="mb-3">
                        <i class="fas fa-user-check fa-3x text-primary"></i>
                    </div>
                    <h3 class="fw-bold">Verified Pros</h3>
                    <p class="text-muted">Every worker on Karigaar 360 undergoes a thorough background check and
                        skill verification.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 h-100">
                    <div class="mb-3">
                        <i class="fas fa-bolt fa-3x text-warning"></i>
                    </div>
                    <h3 class="fw-bold">Fast Response</h3>
                    <p class="text-muted">Post your job and get connected with available professionals in your area
                        within minutes.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 h-100">
                    <div class="mb-3">
                        <i class="fas fa-shield-alt fa-3x text-primary"></i>
                    </div>
                    <h3 class="fw-bold">Secure Payments</h3>
                    <p class="text-muted">Our platform ensures secure transactions and fair pricing for both
                        customers and workers.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Popular Services -->
<section class="py-5 bg-white">
    <div class="container text-center">
        <h2 class="fw-bold mb-5">Popular Services</h2>
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm p-4 h-100 service-card">
                    <i class="fas fa-bolt fa-2x text-warning mb-3"></i>
                    <h6 class="fw-bold">Electrical</h6>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm p-4 h-100 service-card">
                    <i class="fas fa-faucet fa-2x text-primary mb-3"></i>
                    <h6 class="fw-bold">Plumbing</h6>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm p-4 h-100 service-card">
                    <i class="fas fa-hammer fa-2x text-secondary mb-3"></i>
                    <h6 class="fw-bold">Carpentry</h6>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm p-4 h-100 service-card">
                    <i class="fas fa-snowflake fa-2x text-info mb-3"></i>
                    <h6 class="fw-bold">AC Repair</h6>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How it Works -->
<section class="py-5 mb-5">
    <div class="container">
        <h2 class="fw-bold text-center mb-5">How Karigaar 360 Works</h2>
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="d-flex flex-column align-items-center mb-3">
                    <div class="step-num shadow-sm">1</div>
                    <div>
                        <h5 class="fw-bold">Post a Job</h5>
                        <p class="text-muted">Tell us what's broken or what you need installed.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="d-flex flex-column align-items-center mb-3">
                    <div class="step-num shadow-sm">2</div>
                    <div>
                        <h5 class="fw-bold">Get Quotes</h5>
                        <p class="text-muted">Receive competitive bids from verified local Karigaars.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="d-flex flex-column align-items-center mb-3">
                    <div class="step-num shadow-sm">3</div>
                    <div>
                        <h5 class="fw-bold">Job Done</h5>
                        <p class="text-muted">Hire the best pro, get the work done, and pay securely.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>