@{
    ViewData["Title"] = "Home";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Karigaar 360 | Connecting Skilled Hands to Your Needs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css">
    <style>
        .hero-section {
            background: linear-gradient(135deg, #003366 0%, #004080 100%);
            color: white;
            padding: 100px 0;
        }
        .btn-secondary {
            background: #ffc107;
            border: none;
            color: #1a1a1a;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <div class="logo-wrapper me-2">
                    <i class="fas fa-tools text-warning floating"></i>
                </div>
                <span class="fw-bold" style="background: linear-gradient(45deg, #003366, #004d99); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Karigaar 360</span>
            </a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link mx-2" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link mx-2" asp-controller="Worker" asp-action="Register">Join as Worker</a></li>
                    <li class="nav-item ms-lg-3">
                        <a asp-controller="Customer" asp-action="Register" class="btn btn-outline-primary rounded-pill px-4">Get Started</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <section class="hero-section text-center text-lg-start">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 animate-up">
                    <h1 class="hero-title">Connecting Skilled Karigaars to Your Doorstep</h1>
                    <p class="lead mb-4 opacity-75">From plumbing to electrical work, find verified professionals for every task. Reliable, skilled, and ready to help.</p>
                    <div class="d-flex flex-column flex-sm-row gap-3">
                        <a asp-controller="Customer" asp-action="Register" class="btn btn-secondary btn-lg shadow">Hire a Karigaar</a>
                        <a asp-controller="Worker" asp-action="Register" class="btn btn-outline-light btn-lg">Join as a Worker</a>
                    </div>
                </div>
                <div class="col-lg-6 mt-5 mt-lg-0 text-center">
                    <i class="fas fa-hard-hat fa-10x text-warning opacity-50 floating"></i>
                </div>
            </div>
        </div>
    </section>

    <footer class="mt-5">
        <div class="container">
            <div class="text-center opacity-50 pb-3">
                <small>&copy; 2026 Karigaar 360. All rights reserved.</small>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>