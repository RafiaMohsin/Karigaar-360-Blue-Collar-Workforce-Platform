@model IEnumerable<Karigaar360.Models.Job>
@{
    ViewData["Title"] = "My Accepted Jobs";
}

<div class="container py-5 mt-4">
    <div class="row g-4 mb-4 align-items-center">
        <div class="col-md-6 mb-3 mb-md-0">
            <h2 class="fw-bold mb-0">My Accepted Jobs</h2>
            <p class="text-muted">Manage your active projects and track your progress.</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a asp-action="Browse" class="btn btn-outline-primary rounded-pill px-4">
                <i class="fas fa-search me-2"></i> Browse More
            </a>
        </div>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var job in Model.OrderByDescending(j => j.Status == "InProgress"))
            {
                <div class="col-lg-6 animate-up">
                    <div class="card h-100 shadow-sm border-0 job-card dashboard-card">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge @(job.Status == "InProgress" ? "bg-info" : "bg-success") text-dark px-3 py-2 rounded-pill fw-bold">@(job.Status == "InProgress" ? "In Progress" : job.Status)</span>
                                <div class="text-muted small">
                                    <i class="far fa-calendar-check me-1"></i> @job.CreatedAt.ToString("MMM dd, yyyy")
                                </div>
                            </div>
                            <h4 class="fw-bold mb-3">@job.Title</h4>
                            <p class="text-muted mb-4">@job.Description</p>

                            <div class="row g-4 mb-4">
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded-3">
                                        <small class="text-muted d-block">Location</small>
                                        <span class="small fw-semibold">@job.Location</span>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded-3">
                                        <small class="text-muted d-block">Payment</small>
                                        <span class="small fw-semibold text-primary">Rs. @job.OfferedPrice.ToString("F0")</span>
                                    </div>
                                </div>
                            </div>

                            <hr class="opacity-25 mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                @if (job.Status == "InProgress")
                                {
                                    <form asp-action="CompleteJob" asp-route-id="@job.Id" method="post">
                                        <button type="submit" class="btn btn-success rounded-pill px-4 shadow">Mark as Completed</button>
                                    </form>
                                }
                                else
                                {
                                    <div class="text-success fw-bold">
                                        <i class="fas fa-check-circle me-1"></i> Job Completed
                                    </div>
                                    <div class="small text-muted">
                                        Finished: @job.CompletedAt?.ToString("MMM dd")
                                    </div>
                                }
                                <a asp-action="Details" asp-route-id="@job.Id" class="btn btn-outline-primary rounded-pill px-4">View Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 opacity-50 bg-light rounded-4">
                <i class="fas fa-tasks fa-4x mb-3"></i>
                <h3>No accepted jobs yet.</h3>
                <p>Browse available jobs and accept them to see them here.</p>
                <a asp-action="Browse" class="btn btn-primary mt-3">Find Jobs</a>
            </div>
        }
    </div>
</div>
