@model Karigaar360.Models.Job
@{
    ViewData["Title"] = "Job Details";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Title | Karigaar 360</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css">
    <style>
        :root {
            --primary-color: #003366;
            --primary-light: #0066cc;
            --secondary-color: #ffc107;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .detail-card {
            border: none;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
        }

        .detail-header {
            background: linear-gradient(45deg, var(--primary-color), var(--primary-light));
            color: white;
            padding: 30px;
            border-radius: 12px 12px 0 0;
        }

        .detail-title {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .detail-category {
            display: inline-block;
            background: rgba(255, 193, 7, 0.2);
            color: var(--secondary-color);
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: 600;
            margin-right: 15px;
        }

        .detail-status {
            display: inline-block;
            background: rgba(255, 255, 255, 0.2);
            color: white;
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: 600;
        }

        .section-title {
            color: var(--primary-color);
            font-weight: 700;
            font-size: 20px;
            margin-top: 30px;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--primary-light);
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 15px 0;
            border-bottom: 1px solid #e0e0e0;
        }

        .info-label {
            color: #666;
            font-weight: 600;
            font-size: 14px;
            text-transform: uppercase;
        }

        .info-value {
            color: var(--primary-color);
            font-weight: 700;
            font-size: 16px;
        }

        .price-highlight {
            background: rgba(0, 102, 204, 0.05);
            padding: 20px;
            border-left: 4px solid var(--primary-light);
            border-radius: 6px;
            margin: 20px 0;
        }

        .price-box {
            text-align: center;
            padding: 20px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .price-box.fair-price {
            border-color: #28a745;
            background: rgba(40, 167, 69, 0.05);
        }

        .price-box.offered-price {
            border-color: var(--primary-light);
            background: rgba(0, 102, 204, 0.05);
        }

        .price-box-label {
            font-size: 12px;
            color: #999;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .price-box-amount {
            font-size: 28px;
            font-weight: 700;
            color: var(--primary-color);
        }

        .price-box.fair-price .price-box-amount {
            color: #28a745;
        }

        .description-text {
            color: #333;
            font-size: 16px;
            line-height: 1.7;
            background: #f9f9f9;
            padding: 20px;
            border-radius: 8px;
        }

        .action-buttons {
            margin-top: 30px;
            display: flex;
            gap: 15px;
        }

        .btn-primary-gradient {
            background: linear-gradient(45deg, var(--primary-color), var(--primary-light));
            border: none;
            color: white;
            font-weight: 600;
        }

        .btn-primary-gradient:hover {
            background: var(--primary-color);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0, 51, 102, 0.3);
        }

        footer {
            margin-top: auto;
        }

        .meta-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0;
        }

        .meta-item {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 8px;
            border-left: 3px solid var(--primary-light);
        }

        .meta-label {
            font-size: 12px;
            color: #999;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .meta-value {
            font-size: 16px;
            font-weight: 600;
            color: var(--primary-color);
        }
    </style>
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm bg-white">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <div class="logo-wrapper me-2">
                    <i class="fas fa-tools text-warning floating"></i>
                </div>
                <span class="fw-bold" style="background: linear-gradient(45deg, var(--primary-color), var(--primary-light)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Karigaar 360</span>
            </a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="Dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="Logout">Logout</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-5 flex-grow-1">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card detail-card">
                    <!-- Header -->
                    <div class="detail-header">
                        <div class="detail-title">@Model.Title</div>
                        <div>
                            <span class="detail-category">
                                <i class="fas fa-tag me-2"></i>@Model.Category
                            </span>
                            <span class="detail-status">
                                <i class="fas fa-circle me-2"></i>@Model.Status
                            </span>
                        </div>
                    </div>

                    <!-- Body -->
                    <div class="card-body p-4 p-md-5">
                        <!-- Description -->
                        <div>
                            <h5 class="section-title">
                                <i class="fas fa-file-alt me-2"></i>Job Description
                            </h5>
                            <div class="description-text">
                                @Model.Description
                            </div>
                        </div>

                        <!-- Pricing Section -->
                        <h5 class="section-title">
                            <i class="fas fa-dollar-sign me-2"></i>Pricing & Compensation
                        </h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="price-box fair-price">
                                    <div class="price-box-label">Minimum Fair Wage</div>
                                    <div class="price-box-amount">Rs. @Model.FairPrice.ToString("N0")</div>
                                    <small class="text-muted d-block mt-2">@Model.EstimatedHours hours × Rs. 400/hr</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="price-box offered-price">
                                    <div class="price-box-label">Your Offer</div>
                                    <div class="price-box-amount">Rs. @Model.OfferedPrice.ToString("N0")</div>
                                    <small class="text-muted d-block mt-2">What you're paying Karigaars</small>
                                </div>
                            </div>
                        </div>

                        @if (Model.OfferedPrice >= Model.FairPrice)
                        {
                            <div class="price-highlight">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                <strong>Fair wage compliant:</strong> Your offer meets minimum wage requirements.
                            </div>
                        }

                        <!-- Job Details -->
                        <h5 class="section-title">
                            <i class="fas fa-info-circle me-2"></i>Job Details
                        </h5>
                        <div class="meta-info">
                            <div class="meta-item">
                                <div class="meta-label">Estimated Duration</div>
                                <div class="meta-value">@Model.EstimatedHours hours</div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-label">Job Location</div>
                                <div class="meta-value">@Model.Location</div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-label">Posted By</div>
                                <div class="meta-value">@Model.CustomerName</div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-label">Posted On</div>
                                <div class="meta-value">@Model.CreatedAt.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="action-buttons">
                            <a asp-action="MyJobs" class="btn btn-outline-primary btn-lg">
                                <i class="fas fa-arrow-left me-2"></i>Back to My Jobs
                            </a>
                            <a asp-controller="Customer" asp-action="Dashboard" class="btn btn-primary-gradient btn-lg">
                                <i class="fas fa-home me-2"></i>Dashboard
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="mt-5 bg-white border-top py-4">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center opacity-50">
                    <small>&copy; 2026 Karigaar 360. Fair wages guaranteed.</small>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
