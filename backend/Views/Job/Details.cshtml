@model Karigaar360.Models.Job
@{
    ViewData["Title"] = "Job Details";
    var isCustomer = Context.Session.GetInt32("CustomerId") != null;
    var isWorker = Context.Session.GetInt32("WorkerId") != null;
    var currentWorkerId = Context.Session.GetInt32("WorkerId");
}

<div class="container py-5 mt-4 text-start">
    <div class="row justify-content-center">
        <div class="col-lg-9 animate-up">
            <div class="card shadow-lg border-0 overflow-hidden">
                <!-- Header -->
                <div class="p-5 text-white" style="background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <span class="badge bg-white text-primary px-3 py-2 rounded-pill fw-bold mb-3">@Model.Category</span>
                            <h1 class="fw-bold mb-0">@Model.Title</h1>
                        </div>
                        <span class="badge bg-glass text-white px-3 py-2 rounded-pill border border-white border-opacity-25">
                            <i class="fas fa-circle me-1 small @(Model.Status == "Open" ? "text-info" : Model.Status == "InProgress" ? "text-warning" : "text-success")"></i> @(Model.Status == "InProgress" ? "In Progress" : Model.Status)
                        </span>
                    </div>
                </div>

                <!-- Body -->
                <div class="card-body p-4 p-md-5">
                    @await Html.PartialAsync("_JobStatusTracker", Model.Status)
                    
                    <div class="row g-5">
                        <div class="col-md-7">
                            <h5 class="fw-bold mb-4 text-primary border-bottom pb-2">Job Description</h5>
                            <div class="p-4 bg-light rounded-4 mb-5">
                                <p class="mb-0 text-muted" style="line-height: 1.8;">@Model.Description</p>
                            </div>

                            <h5 class="fw-bold mb-4 text-primary border-bottom pb-2">Location & Details</h5>
                            <div class="row g-4">
                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center">
                                        <div class="p-3 bg-accent rounded-3 me-3 text-primary">
                                            <i class="fas fa-map-marker-alt fa-lg"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block text-uppercase fw-bold text-xs">Location</small>
                                            <span class="fw-bold">@Model.Location</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center">
                                        <div class="p-3 bg-accent rounded-3 me-3 text-primary">
                                            <i class="fas fa-clock fa-lg"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block text-uppercase fw-bold text-xs">Duration</small>
                                            <span class="fw-bold">@Model.EstimatedHours Hours</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center">
                                        <div class="p-3 bg-accent rounded-3 me-3 text-primary">
                                            <i class="fas fa-user-circle fa-lg"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block text-uppercase fw-bold text-xs">Posted By</small>
                                            <span class="fw-bold">@Model.CustomerName</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center">
                                        <div class="p-3 bg-accent rounded-3 me-3 text-primary">
                                            <i class="fas fa-calendar-alt fa-lg"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block text-uppercase fw-bold text-xs">Date</small>
                                            <span class="fw-bold">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-5">
                            <div class="p-4 bg-light rounded-4 mb-4">
                                <h5 class="fw-bold mb-4">Pricing Summary</h5>
                                <div class="mb-4">
                                    <small class="text-muted d-block mb-1">Offered Price</small>
                                    <h2 class="fw-bold text-primary mb-0">Rs. @Model.OfferedPrice.ToString("F0")</h2>
                                </div>
                                <div class="mb-4">
                                    <div class="p-3 bg-white rounded-3 border border-success border-opacity-25 border-dashed">
                                        <small class="text-muted d-block mb-1">Fair Wage Policy</small>
                                        <span class="text-success fw-bold">Compliant <i class="fas fa-check-circle ms-1"></i></span>
                                        <p class="mb-0 small text-muted mt-1">Meets minimum wage of Rs. 400/hr.</p>
                                    </div>
                                </div>
                            </div>

                            @if (TempData["Success"] != null)
                            {
                                <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4">
                                    <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                                </div>
                            }
                            @if (TempData["Error"] != null)
                            {
                                <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4">
                                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                                </div>
                            }

                            @if (Model.WorkerId != null)
                            {
                                <div class="p-4 border border-primary border-opacity-10 rounded-4 mb-4">
                                    <h6 class="fw-bold mb-3">Assigned Professional</h6>
                                    <div class="d-flex align-items-center">
                                        <i class="fas fa-user-hard-hat fa-2x text-primary me-3"></i>
                                        <div>
                                            <span class="fw-bold d-block">@Model.WorkerName</span>
                                            <span class="badge bg-light text-primary">Assigned Professional</span>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Dynamic Logic -->
                            <div class="d-grid gap-3 mt-5">
                                @if (isWorker && Model.Status == "Open")
                                {
                                    var alreadyApplied = ViewBag.AlreadyApplied as bool? ?? false;
                                    var canApply = ViewBag.CanApply as bool? ?? false;
                                    if (!canApply)
                                    {
                                        <button type="button" class="btn btn-outline-secondary btn-lg w-100 rounded-pill shadow" disabled>
                                            Not in Your Profession
                                        </button>
                                    }
                                    else if (alreadyApplied)
                                    {
                                        <button type="button" class="btn btn-outline-secondary btn-lg w-100 rounded-pill shadow" disabled>
                                            Request Sent
                                        </button>
                                    }
                                    else
                                    {
                                        <form asp-action="ApplyForJob" asp-route-id="@Model.Id" method="post" data-prevent-double-submit="true">
                                            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow">Apply For This Job</button>
                                        </form>
                                    }
                                }
                                else if (isWorker && Model.Status == "InProgress" && Model.WorkerId == currentWorkerId)
                                {
                                    <form asp-action="CompleteJob" asp-route-id="@Model.Id" method="post" data-prevent-double-submit="true">
                                        <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill shadow">Mark as Completed</button>
                                    </form>
                                }

                                @if (isCustomer && Model.CustomerId == Context.Session.GetInt32("CustomerId"))
                                {
                                    @if (Model.Status == "Open")
                                    {
                                        <a asp-action="ViewApplicants" asp-route-jobId="@Model.Id" class="btn btn-primary btn-lg rounded-pill shadow">View Applicants</a>
                                    }
                                    <a asp-action="MyJobs" class="btn btn-outline-primary btn-lg rounded-pill">Back to My Jobs</a>
                                }
                                else if (isWorker)
                                {
                                    <a asp-action="Browse" class="btn btn-outline-primary btn-lg rounded-pill">Back to Browse</a>
                                }
                                else
                                {
                                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-lg rounded-pill">Go Home</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
