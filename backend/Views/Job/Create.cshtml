@model Karigaar360.Models.Job
@{
    ViewData["Title"] = "Post a Job";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post a Job | Karigaar 360</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css">
    <style>
        :root {
            --primary-color: #003366;
            --primary-light: #0066cc;
            --secondary-color: #ffc107;
            --success-color: #28a745;
            --danger-color: #dc3545;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .fair-price-box {
            background: linear-gradient(135deg, rgba(0, 51, 102, 0.1) 0%, rgba(0, 102, 204, 0.1) 100%);
            border-left: 4px solid var(--primary-color);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .fair-price-label {
            font-size: 14px;
            color: #666;
            margin-bottom: 5px;
        }

        .fair-price-amount {
            font-size: 28px;
            font-weight: 700;
            color: var(--primary-color);
        }

        .price-error {
            display: none;
            background-color: rgba(220, 53, 69, 0.1);
            border: 1px solid var(--danger-color);
            color: var(--danger-color);
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 15px;
            font-weight: 500;
        }

        .price-warning {
            background-color: rgba(255, 193, 7, 0.1);
            border: 1px solid var(--secondary-color);
            color: #856404;
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 15px;
        }

        .form-control, .form-select {
            border: 2px solid #e0e0e0;
            transition: all 0.3s ease;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(0, 51, 102, 0.25);
        }

        .btn-submit {
            background: linear-gradient(45deg, var(--primary-color), var(--primary-light));
            border: none;
            color: white;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-submit:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0, 51, 102, 0.3);
            color: white;
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .form-label {
            color: var(--primary-color);
            font-weight: 600;
            margin-bottom: 8px;
        }

        .text-danger {
            color: var(--danger-color) !important;
            font-size: 13px;
            margin-top: 4px;
        }

        .card {
            border: none;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
            transition: all 0.3s ease;
        }

        .card-header {
            background: linear-gradient(45deg, var(--primary-color), var(--primary-light));
            border-radius: 8px 8px 0 0 !important;
        }

        .category-select {
            cursor: pointer;
        }

        .input-group {
            margin-bottom: 20px;
        }

        footer {
            margin-top: auto;
        }
    </style>
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm bg-white">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <div class="logo-wrapper me-2">
                    <i class="fas fa-tools text-warning floating"></i>
                </div>
                <span class="fw-bold" style="background: linear-gradient(45deg, var(--primary-color), var(--primary-light)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Karigaar 360</span>
            </a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="Dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="Logout">Logout</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container my-5 flex-grow-1">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">
                <div class="card shadow-lg p-4 p-md-5">
                    <div class="card-header mb-4">
                        <div class="text-center">
                            <i class="fas fa-briefcase fa-3x text-white mb-3" style="display: block;"></i>
                            <h2 class="fw-bold text-white mb-2">Post a New Job</h2>
                            <p class="text-white-50 mb-0">Fair wage guaranteed for Karigaars</p>
                        </div>
                    </div>

                    <div class="card-body">
                        <!-- Fair Price Display Box -->
                        <div class="fair-price-box" id="fairPriceBox">
                            <div class="fair-price-label">
                                <i class="fas fa-shield-alt me-2"></i>Minimum Fair Wage (Legal)
                            </div>
                            <div class="fair-price-amount" id="fairPriceDisplay">
                                Rs. 0
                            </div>
                            <small class="text-muted d-block mt-2">Based on 400 Rs/hour × estimated hours</small>
                        </div>

                        <!-- Error Message -->
                        <div class="price-error" id="priceError">
                            <i class="fas fa-exclamation-circle me-2"></i><span id="errorText"></span>
                        </div>

                        <!-- Warning Message -->
                        <div class="price-warning" id="priceWarning" style="display: none;">
                            <i class="fas fa-info-circle me-2"></i>Your offer is below the minimum fair wage. Update to meet legal requirements.
                        </div>

                        <form asp-action="Create" method="post" id="jobForm">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <!-- Job Title -->
                            <div class="mb-4">
                                <label asp-for="Title" class="form-label">Job Title</label>
                                <input asp-for="Title" class="form-control form-control-lg" placeholder="e.g., Fix water leak in bathroom">
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <!-- Category -->
                            <div class="mb-4">
                                <label asp-for="Category" class="form-label">Service Category</label>
                                <select asp-for="Category" class="form-select form-select-lg category-select">
                                    <option value="">Select a category...</option>
                                    <option>Electrician</option>
                                    <option>Plumber</option>
                                    <option>Carpenter</option>
                                    <option>Painter</option>
                                    <option>AC Technician</option>
                                </select>
                                <span asp-validation-for="Category" class="text-danger"></span>
                            </div>

                            <!-- Description -->
                            <div class="mb-4">
                                <label asp-for="Description" class="form-label">Job Description</label>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe the work in detail. What needs to be done? What materials are needed?"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <!-- Estimated Hours -->
                            <div class="mb-4">
                                <label asp-for="EstimatedHours" class="form-label">Estimated Hours to Complete</label>
                                <div class="input-group">
                                    <input asp-for="EstimatedHours" type="number" class="form-control form-control-lg" 
                                           placeholder="e.g., 4" id="EstimatedHours" onchange="calculateFairPrice()" oninput="calculateFairPrice()">
                                    <span class="input-group-text bg-light">hours</span>
                                </div>
                                <span asp-validation-for="EstimatedHours" class="text-danger"></span>
                            </div>

                            <!-- Offered Price -->
                            <div class="mb-4">
                                <label asp-for="OfferedPrice" class="form-label">Your Offered Price</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light">Rs.</span>
                                    <input asp-for="OfferedPrice" type="number" step="0.01" class="form-control form-control-lg" 
                                           placeholder="e.g., 1600" id="OfferedPrice" onchange="calculateFairPrice()" oninput="calculateFairPrice()">
                                </div>
                                <span asp-validation-for="OfferedPrice" class="text-danger"></span>
                            </div>

                            <!-- Location -->
                            <div class="mb-4">
                                <label asp-for="Location" class="form-label">Job Location</label>
                                <input asp-for="Location" class="form-control form-control-lg" placeholder="e.g., Gulshan-e-Iqbal, Karachi">
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>

                            <!-- Submit Button -->
                            <button type="submit" class="btn btn-submit btn-lg w-100 py-3 mt-4" id="submitBtn">
                                <i class="fas fa-arrow-right me-2"></i>Post Job
                            </button>
                        </form>

                        <div class="text-center mt-4 pt-3 border-top">
                            <a asp-controller="Customer" asp-action="Dashboard" class="text-primary fw-bold">Back to Dashboard</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="mt-5 bg-white border-top py-4">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center opacity-50">
                    <small>&copy; 2026 Karigaar 360. Fair wages guaranteed.</small>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const MINIMUM_WAGE_PER_HOUR = 400;

        function calculateFairPrice() {
            const hoursInput = document.getElementById('EstimatedHours');
            const priceInput = document.getElementById('OfferedPrice');
            const fairPriceDisplay = document.getElementById('fairPriceDisplay');
            const priceError = document.getElementById('priceError');
            const errorText = document.getElementById('errorText');
            const priceWarning = document.getElementById('priceWarning');
            const submitBtn = document.getElementById('submitBtn');

            const hours = parseInt(hoursInput.value) || 0;
            const fairPrice = hours * MINIMUM_WAGE_PER_HOUR;
            const offeredPrice = parseFloat(priceInput.value) || 0;

            // Update fair price display
            fairPriceDisplay.innerHTML = 'Rs. ' + fairPrice.toLocaleString('en-PK');

            // Check if prices are entered
            if (hours > 0 && offeredPrice > 0) {
                if (offeredPrice < fairPrice) {
                    errorText.textContent = `Please offer at least Rs. ${fairPrice.toLocaleString('en-PK')} (minimum fair wage)`;
                    priceError.style.display = 'block';
                    priceWarning.style.display = 'block';
                    submitBtn.disabled = true;
                } else {
                    priceError.style.display = 'none';
                    priceWarning.style.display = 'none';
                    submitBtn.disabled = false;
                }
            } else {
                priceError.style.display = 'none';
                priceWarning.style.display = 'none';
            }
        }

        // Initial calculation on page load
        document.addEventListener('DOMContentLoaded', function() {
            calculateFairPrice();
        });
    </script>
</body>
</html>
