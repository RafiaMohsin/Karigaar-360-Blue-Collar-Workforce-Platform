@model Karigaar360.Models.Job
@{
    ViewData["Title"] = "Post a New Job";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 animate-up">
            <div class="card shadow-lg border-0 p-4 p-md-5">
                <div class="text-center mb-5">
                    <div class="mb-4">
                        <i class="fas fa-briefcase fa-4x text-primary opacity-25"></i>
                    </div>
                    <h2 class="fw-bold">Post a New Job</h2>
                    <p class="text-muted">Find the best local Karigaar for your needs. Fair wages guaranteed.</p>
                </div>

                <div class="fair-price-box p-4 rounded-4 mb-5 shadow-sm border-start border-4 border-primary bg-accent">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <small class="text-muted d-block fw-bold text-uppercase mb-1">Minimum Fair Wage (Legal)</small>
                            <h3 class="fw-bold text-primary mb-0" id="fairPriceDisplay">Rs. 0</h3>
                        </div>
                        <div class="text-end">
                            <i class="fas fa-shield-check fa-2x text-primary opacity-50"></i>
                        </div>
                    </div>
                    <p class="mt-2 mb-0 small text-muted">Automatically calculated based on Rs. 400/hr minimum wage.</p>
                </div>

                <form asp-action="Create" method="post" id="jobForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="Title" class="form-label fw-bold">Job Title</label>
                            <input asp-for="Title" class="form-control" placeholder="e.g. Fix leaking kitchen faucet">
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Category" class="form-label fw-bold">Category</label>
                            <select asp-for="Category" class="form-select">
                                <option value="">Select Category</option>
                                <option>Electrician</option>
                                <option>Plumber</option>
                                <option>Carpenter</option>
                                <option>Painter</option>
                                <option>AC Technician</option>
                            </select>
                            <span asp-validation-for="Category" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Location" class="form-label fw-bold">Location</label>
                            <input asp-for="Location" class="form-control" placeholder="e.g. Clifton, Karachi">
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EstimatedHours" class="form-label fw-bold">Estimated Time <span class="fw-normal text-muted">(Hours)</span></label>
                            <div class="input-group">
                                <input asp-for="EstimatedHours" type="number" class="form-control" id="EstimatedHours" oninput="calculateFairPrice()">
                                <span class="input-group-text bg-light"><i class="fas fa-clock text-muted"></i></span>
                            </div>
                            <span asp-validation-for="EstimatedHours" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="OfferedPrice" class="form-label fw-bold">Your Offer <span class="fw-normal text-muted">(Rs.)</span></label>
                            <div class="input-group">
                                <input asp-for="OfferedPrice" type="number" class="form-control" id="OfferedPrice" oninput="calculateFairPrice()">
                                <span class="input-group-text bg-light"><i class="fas fa-coins text-muted"></i></span>
                            </div>
                            <span asp-validation-for="OfferedPrice" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-bold">Job Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Detail the work requirements..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="col-12" id="priceWarning" style="display:none;">
                            <div class="alert alert-warning border-0 shadow-sm small py-3">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <span id="errorText">Please offer at least the minimum fair wage.</span>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill shadow-sm fw-bold" id="submitBtn">
                                Post Job Now
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const MINIMUM_WAGE_PER_HOUR = 400;

        function calculateFairPrice() {
            const hoursInput = document.getElementById('EstimatedHours');
            const priceInput = document.getElementById('OfferedPrice');
            const fairPriceDisplay = document.getElementById('fairPriceDisplay');
            const priceWarning = document.getElementById('priceWarning');
            const errorText = document.getElementById('errorText');
            const submitBtn = document.getElementById('submitBtn');

            const hours = parseInt(hoursInput.value) || 0;
            const fairPrice = hours * MINIMUM_WAGE_PER_HOUR;
            const offeredPrice = parseFloat(priceInput.value) || 0;

            fairPriceDisplay.innerHTML = 'Rs. ' + fairPrice.toLocaleString();

            if (hours > 0 && offeredPrice > 0) {
                if (offeredPrice < fairPrice) {
                    errorText.textContent = `Minimum fair wage for ${hours} hours is Rs. ${fairPrice.toLocaleString()}. Please adjust your offer.`;
                    priceWarning.style.display = 'block';
                    submitBtn.disabled = true;
                } else {
                    priceWarning.style.display = 'none';
                    submitBtn.disabled = false;
                }
            } else {
                priceWarning.style.display = 'none';
                submitBtn.disabled = false;
            }
        }
    </script>
}
