@model IEnumerable<Karigaar360.Models.JobApplication>
@{
    ViewData["Title"] = "My Applications";
}

<div class="container py-5 mt-4">
    <div class="row g-4 mb-5 align-items-center animate-up">
        <div class="col-md-6">
            <h2 class="fw-bold mb-0">My Applications</h2>
            <p class="text-muted mb-0">Track the status of all your job applications.</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a asp-action="Browse" class="btn btn-primary rounded-pill px-4 shadow">
                <i class="fas fa-search me-2"></i> Find More Jobs
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 opacity-50 animate-up">
            <i class="fas fa-paper-plane fa-4x mb-3 text-muted"></i>
            <h3>You haven't applied to any jobs yet</h3>
            <p>Go to the marketplace and start applying for jobs that match your skills.</p>
            <a asp-action="Browse" class="btn btn-primary mt-3">Browse Jobs</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var app in Model)
            {
                <div class="col-lg-6 animate-up">
                    <div class="card h-100 shadow-sm border-0 job-card">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <div>
                                    <span class="badge bg-light text-primary px-3 py-2 rounded-pill fw-bold mb-2">@app.Job?.Category</span>
                                    <h4 class="fw-bold mb-1">@app.Job?.Title</h4>
                                </div>
                                <span class="badge @(app.Status == "Pending" ? "bg-warning text-dark" : app.Status == "Accepted" ? "bg-success" : "bg-danger") px-3 py-2 rounded-pill fw-bold">
                                    <i class="fas @(app.Status == "Pending" ? "fa-clock" : app.Status == "Accepted" ? "fa-check-circle" : "fa-times-circle") me-1"></i> @app.Status
                                </span>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center">
                                        <i class="fas fa-map-marker-alt text-muted me-3"></i>
                                        <div>
                                            <span class="small text-muted d-block">Location</span>
                                            <span class="fw-bold">@app.Job.Location</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center">
                                        <i class="fas fa-wallet text-muted me-3"></i>
                                        <div>
                                            <span class="small text-muted d-block">Offered Budget</span>
                                            <span class="fw-bold text-primary">Rs. @app.Job.OfferedPrice.ToString("F0")</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center">
                                        <i class="fas fa-calendar-alt text-muted me-3"></i>
                                        <div>
                                            <span class="small text-muted d-block">Applied On</span>
                                            <span class="fw-bold">@app.AppliedAt.ToString("MMM dd, yyyy")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <hr class="opacity-25 mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <a asp-action="Details" asp-route-id="@app.JobId" class="btn btn-outline-primary rounded-pill px-4">See Job Details</a>
                                @if (app.Status == "Accepted")
                                {
                                    <span class="text-success fw-bold"><i class="fas fa-star me-2"></i>Hired!</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
