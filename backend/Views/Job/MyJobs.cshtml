@model IEnumerable<Karigaar360.Models.Job>
@{
    ViewData["Title"] = "My Posted Jobs";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Posted Jobs | Karigaar 360</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css">
    <style>
        :root {
            --primary-color: #003366;
            --primary-light: #0066cc;
            --secondary-color: #ffc107;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .job-card {
            border: none;
            border-left: 4px solid var(--primary-color);
            transition: all 0.3s ease;
            margin-bottom: 20px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        }

        .job-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0, 51, 102, 0.15);
        }

        .job-title {
            color: var(--primary-color);
            font-weight: 700;
            font-size: 18px;
            margin-bottom: 8px;
        }

        .job-category {
            display: inline-block;
            background: rgba(0, 102, 204, 0.1);
            color: var(--primary-light);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 12px;
        }

        .job-description {
            color: #666;
            font-size: 14px;
            line-height: 1.5;
            margin-bottom: 15px;
        }

        .price-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-top: 1px solid #e0e0e0;
            margin-bottom: 12px;
        }

        .price-column {
            text-align: center;
        }

        .price-label {
            font-size: 12px;
            color: #999;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .price-amount {
            font-size: 18px;
            font-weight: 700;
            color: var(--primary-color);
        }

        .fair-price {
            color: #28a745;
        }

        .status-badge {
            display: inline-block;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
        }

        .status-open {
            background: rgba(40, 167, 69, 0.1);
            color: #28a745;
        }

        .status-in-progress {
            background: rgba(0, 123, 255, 0.1);
            color: #007bff;
        }

        .status-completed {
            background: rgba(108, 117, 125, 0.1);
            color: #6c757d;
        }

        .job-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 15px;
            padding-top: 12px;
            border-top: 1px solid #e0e0e0;
        }

        .job-date {
            font-size: 12px;
            color: #999;
        }

        .action-buttons {
            display: flex;
            gap: 8px;
        }

        .btn-view {
            background: var(--primary-color);
            color: white;
            border: none;
            padding: 6px 16px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .btn-view:hover {
            background: var(--primary-light);
            color: white;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
        }

        .empty-state-icon {
            font-size: 64px;
            color: #ddd;
            margin-bottom: 20px;
        }

        .empty-state-text {
            color: #999;
            margin-bottom: 20px;
        }

        footer {
            margin-top: auto;
        }
    </style>
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm bg-white">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <div class="logo-wrapper me-2">
                    <i class="fas fa-tools text-warning floating"></i>
                </div>
                <span class="fw-bold" style="background: linear-gradient(45deg, var(--primary-color), var(--primary-light)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Karigaar 360</span>
            </a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="Dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="Logout">Logout</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-5 flex-grow-1">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="mb-4">
                    <h1 class="fw-bold" style="color: var(--primary-color);">
                        <i class="fas fa-briefcase me-3"></i>My Posted Jobs
                    </h1>
                    <p class="text-muted">Track and manage all your job postings</p>
                </div>

                @if (Model.Any())
                {
                    @foreach (var job in Model)
                    {
                        <div class="card job-card">
                            <div class="card-body">
                                <!-- Job Title and Category -->
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <div class="job-title">@job.Title</div>
                                        <div class="job-category">@job.Category</div>
                                    </div>
                                    <span class="status-badge @("status-" + job.Status.ToLower())">
                                        <i class="fas fa-check-circle me-1"></i>@job.Status
                                    </span>
                                </div>

                                <!-- Description -->
                                <div class="job-description">
                                    @if (job.Description.Length > 150)
                                    {
                                        @job.Description.Substring(0, 150)<text>...</text>
                                    }
                                    else
                                    {
                                        @job.Description
                                    }
                                </div>

                                <!-- Prices -->
                                <div class="price-row">
                                    <div class="price-column">
                                        <div class="price-label">Fair Price (Minimum Wage)</div>
                                        <div class="price-amount fair-price">Rs. @job.FairPrice.ToString("N0")</div>
                                    </div>
                                    <div class="price-column">
                                        <div class="price-label">Your Offer</div>
                                        <div class="price-amount">Rs. @job.OfferedPrice.ToString("N0")</div>
                                    </div>
                                    <div class="price-column">
                                        <div class="price-label">Estimated Hours</div>
                                        <div class="price-amount">@job.EstimatedHours <small style="font-size: 12px;">hrs</small></div>
                                    </div>
                                </div>

                                <!-- Meta Information -->
                                <div class="job-meta">
                                    <div class="job-date">
                                        <i class="fas fa-calendar-alt me-2"></i>Posted: @job.CreatedAt.ToString("dd MMM yyyy")
                                    </div>
                                    <div class="action-buttons">
                                        <a asp-action="Details" asp-route-id="@job.Id" class="btn-view">
                                            <i class="fas fa-eye me-1"></i>View Details
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="card job-card">
                        <div class="card-body">
                            <div class="empty-state">
                                <div class="empty-state-icon">
                                    <i class="fas fa-inbox"></i>
                                </div>
                                <h4 class="empty-state-text">No jobs posted yet</h4>
                                <p class="text-muted mb-4">Start finding qualified Karigaars by posting your first job</p>
                                <a asp-action="Create" class="btn btn-primary btn-lg">
                                    <i class="fas fa-plus-circle me-2"></i>Post Your First Job
                                </a>
                            </div>
                        </div>
                    </div>
                }

                <div class="mt-4">
                    <a asp-controller="Customer" asp-action="Dashboard" class="btn btn-outline-primary">
                        <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>

    <footer class="mt-5 bg-white border-top py-4">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center opacity-50">
                    <small>&copy; 2026 Karigaar 360. Fair wages guaranteed.</small>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
