@model IEnumerable<Karigaar360.Models.Job>
@{
    ViewData["Title"] = "My Posted Jobs";
}

<div class="container py-5 mt-4">
    <div class="row g-4 mb-4 align-items-center">
        <div class="col-md-6 mb-3 mb-md-0">
            <h2 class="fw-bold mb-0">My Posted Jobs</h2>
            <p class="text-muted">Track and manage all your job postings and worker quotes.</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow">
                <i class="fas fa-plus me-2"></i> Post a New Job
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var job in Model)
            {
                <div class="col-lg-6 animate-up">
                    <div class="card h-100 shadow-sm border-0 job-card dashboard-card">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <span class="badge bg-light text-primary px-3 py-2 rounded-pill fw-bold mb-2 d-inline-block">@job.Category</span>
                                    <h4 class="fw-bold mb-1">@job.Title</h4>
                                </div>
                                <span class="badge @(job.Status == "Open" ? "bg-info" : job.Status == "InProgress" ? "bg-warning text-dark" : "bg-success") px-3 py-2 rounded-pill fw-bold">
                                    <i class="fas fa-circle me-1 small"></i> @(job.Status == "InProgress" ? "In Progress" : job.Status)
                                </span>
                            </div>
                            
                            <p class="text-muted mb-4 line-clamp-2">@job.Description</p>

                            <div class="row g-3 mb-4">
                                <div class="col-sm-4">
                                    <div class="p-3 bg-light rounded-3 text-center">
                                        <small class="text-muted d-block uppercase text-xs fw-bold">Fair Price</small>
                                        <span class="fw-bold text-success">Rs. @job.FairPrice.ToString("F0")</span>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="p-3 bg-light rounded-3 text-center">
                                        <small class="text-muted d-block uppercase text-xs fw-bold">Your Offer</small>
                                        <span class="fw-bold text-primary">Rs. @job.OfferedPrice.ToString("F0")</span>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="p-3 bg-light rounded-3 text-center">
                                        <small class="text-muted d-block uppercase text-xs fw-bold">Hours</small>
                                        <span class="fw-bold">@job.EstimatedHours hrs</span>
                                    </div>
                                </div>
                            </div>

                            @if (job.WorkerId != null)
                            {
                                <div class="d-flex align-items-center p-3 bg-accent rounded-3 mb-4">
                                    <i class="fas fa-user-hard-hat text-primary me-3 fa-lg"></i>
                                    <div>
                                        <small class="text-muted d-block">Assigned Karigaar</small>
                                        <span class="fw-bold">@job.WorkerName</span>
                                    </div>
                                </div>
                            }

                            <hr class="opacity-25 mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="text-muted small">
                                    <i class="far fa-calendar-alt me-1"></i> Posted @job.CreatedAt.ToString("MMM dd, yyyy")
                                </div>
                                <div class="btn-group gap-2">
                                    <a asp-action="Details" asp-route-id="@job.Id" class="btn btn-outline-secondary rounded-pill px-4">Details</a>
                                    @if (job.Status == "Open")
                                    {
                                        <a asp-action="ViewApplicants" asp-route-jobId="@job.Id" class="btn btn-primary rounded-pill px-4">View Applicants</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 opacity-50 bg-light rounded-4">
                <i class="fas fa-folder-open fa-4x mb-3"></i>
                <h3>No jobs posted yet.</h3>
                <p>Start by posting a job to find the best Karigaars for your project.</p>
                <a asp-action="Create" class="btn btn-primary mt-3 rounded-pill px-5 shadow">Post Your First Job</a>
            </div>
        }
    </div>
</div>
