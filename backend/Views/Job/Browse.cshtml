@model Karigaar360.Models.JobBrowseViewModel
@{
    ViewData["Title"] = "Browse Available Jobs";
}

<div class="container py-5 mt-4">
    <div class="row g-4 mb-4 align-items-center">
        <div class="col-md-6 mb-3 mb-md-0">
            <h2 class="fw-bold mb-0">Discover New Opportunities</h2>
            <p class="text-muted mb-0">Find the best jobs in your area and project area.</p>
            <small class="text-primary fw-semibold">Showing jobs for: @Model.WorkerProfession</small>
        </div>
        <div class="col-md-6 text-md-end">
            <form asp-action="Browse" method="get" class="d-flex justify-content-end">
                <div class="input-group shadow-sm rounded-pill overflow-hidden bg-white px-3 align-items-center">
                    <i class="fas fa-search text-muted me-2"></i>
                    <input name="searchTerm" value="@Model.SearchTerm" type="text" class="form-control border-0 bg-transparent px-2" placeholder="Search by title, description, or location..." />
                    <button type="submit" class="btn btn-primary rounded-pill px-3 ms-2">Search</button>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="row g-4">
        @if (Model != null && Model.Jobs.Any())
        {
            @foreach (var job in Model.Jobs)
            {
                var alreadyApplied = Model.AppliedJobIds.Contains(job.Id);
                <div class="col-lg-4 col-md-6 animate-up">
                    <div class="card h-100 shadow-sm border-0 job-card dashboard-card">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge bg-light text-primary px-3 py-2 rounded-pill fw-bold">@job.Category</span>
                                <div class="text-muted small">
                                    <i class="far fa-clock me-1"></i> @job.CreatedAt.ToString("MMM dd")
                                </div>
                            </div>
                            <h4 class="fw-bold mb-3">@job.Title</h4>
                            <p class="text-muted mb-4 line-clamp-3">@job.Description</p>
                            <div class="d-flex align-items-center mb-4">
                                <i class="fas fa-map-marker-alt text-primary me-2"></i>
                                <span class="small fw-semibold">@job.Location</span>
                            </div>
                            <hr class="opacity-25 mb-4">
                            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                <a asp-action="Details" asp-route-id="@job.Id" class="btn btn-outline-secondary rounded-pill px-3">Details</a>
                                <form asp-action="ApplyForJob" asp-route-id="@job.Id" method="post" data-prevent-double-submit="true">
                                    <button type="submit" class="btn @(alreadyApplied ? "btn-outline-secondary" : "btn-primary") rounded-pill px-4 shadow" @(alreadyApplied ? "disabled" : string.Empty)>
                                        @(alreadyApplied ? "Request Sent" : "Apply")
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 opacity-50 bg-light rounded-4">
                <i class="fas fa-search fa-4x mb-3"></i>
                <h3>No jobs match your search.</h3>
                <p>Try adjusting the search term or check back later for new projects in your profession.</p>
            </div>
        }
    </div>
</div>
